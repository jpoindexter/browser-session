{
  "name": "browser-session",
  "version": "0.1.0",
  "description": "Reuse your real logged-in browser session from Node — read + decrypt Brave/Chrome/Edge cookies (zero deps), and open any login-walled / JS-rendered page in a headless browser with that session.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "browser-session": "dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "x": "tsx src/cli.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "cookies",
    "browser-cookies",
    "chrome-cookies",
    "brave",
    "edge",
    "session",
    "playwright",
    "headless",
    "scraping",
    "cookies-from-browser",
    "macos",
    "typescript"
  ],
  "author": "Jason Poindexter",
  "license": "MIT",
  "optionalDependencies": {
    "playwright-core": "^1.48.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
